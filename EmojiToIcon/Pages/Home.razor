@page "/"
@inject IJSRuntime JS

<div class="container py-5" style="max-width: 540px;">
    <h1 class="mb-1">Emoji to Icon</h1>
    <p class="text-muted mb-4">Generate PNG icons from any emoji.</p>

    <div class="mb-3">
        <label class="form-label fw-semibold" for="emojiInput">Emoji</label>
        <input id="emojiInput"
               type="text"
               class="form-control form-control-lg"
               style="font-size: 2rem;"
               placeholder="0xDEADBEEF"
               @oninput="OnEmojiInput" />
    </div>

    <div class="mb-4 d-flex justify-content-center align-items-center bg-light rounded"
         style="height: 220px;">
        @if (!string.IsNullOrWhiteSpace(emoji))
        {
            <canvas id="preview" width="192" height="192"></canvas>
        }
        else
        {
            <span class="text-muted">Preview will appear here</span>
        }
    </div>

    <div class="d-grid gap-2">
        <button class="btn btn-outline-secondary"
                disabled="@(string.IsNullOrWhiteSpace(emoji))"
                @onclick="() => DownloadAsync(32)">
            Download favicon.png <span class="text-muted small">(32×32)</span>
        </button>
        <button class="btn btn-outline-secondary"
                disabled="@(string.IsNullOrWhiteSpace(emoji))"
                @onclick="() => DownloadAsync(192)">
            Download icon-192.png <span class="text-muted small">(192×192)</span>
        </button>
        <button class="btn btn-outline-secondary"
                disabled="@(string.IsNullOrWhiteSpace(emoji))"
                @onclick="() => DownloadAsync(512)">
            Download icon-512.png <span class="text-muted small">(512×512)</span>
        </button>
    </div>
</div>

@code {
    private string emoji = string.Empty;

    private async Task OnEmojiInput(ChangeEventArgs e)
    {
        var input = e.Value?.ToString() ?? string.Empty;
        var enumerator = System.Globalization.StringInfo.GetTextElementEnumerator(input);
        emoji = enumerator.MoveNext() ? enumerator.GetTextElement() : string.Empty;

        if (!string.IsNullOrWhiteSpace(emoji))
        {
            await Task.Yield();
            await RenderPreviewAsync();
        }
    }

    private async Task RenderPreviewAsync()
    {
        await JS.InvokeVoidAsync("eval", $$"""
            (function() {
                const canvas = document.getElementById('preview');
                if (!canvas) return;
                const size = canvas.width;
                const ctx = canvas.getContext('2d');
                ctx.clearRect(0, 0, size, size);
                ctx.font = (size * 0.82) + 'px serif';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText('{{emoji}}', size / 2, size / 2);
            })();
            """);
    }

    private async Task DownloadAsync(int size)
    {
        string filename = size switch
        {
            32 => "favicon.png",
            192 => "icon-192.png",
            512 => "icon-512.png",
            _ => $"icon-{size}.png"
        };

        if (string.IsNullOrWhiteSpace(emoji)) return;



        await JS.InvokeVoidAsync("eval", $$"""
            (function() {
                const canvas = document.createElement('canvas');
                canvas.width = {{size}};
                canvas.height = {{size}};
                const ctx = canvas.getContext('2d');
                ctx.font = ({{size}} * 0.82) + 'px serif';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText('{{emoji}}', {{size}} / 2, {{size}} / 2);
                const link = document.createElement('a');
                link.download = '{{filename}}';
                link.href = canvas.toDataURL('image/png');
                link.click();
            })();
            """);
    }
}
